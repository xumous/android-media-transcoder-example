<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
                                   xmlns:app="http://schemas.android.com/apk/res-auto"
                                   android:layout_width="match_parent"
                                   android:layout_height="wrap_content"
                                   android:layout_margin="4dp"
                                   app:cardCornerRadius="8dp"
                                   app:cardElevation="2dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

        <!-- 选择框 -->
        <CheckBox
                android:id="@+id/cb_select"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"/>

        <!-- 类型图标 -->
        <ImageView
                android:id="@+id/iv_type"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="文件类型"
                android:src="@drawable/ic_video"/>

        <!-- 内容区域 -->
        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

            <!-- 文件名 -->
            <TextView
                    android:id="@+id/tv_file_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="middle"
                    android:maxLines="1"
                    android:text="filename.mp4"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            <!-- 状态和进度行 -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="等待中"
                        android:textSize="12sp"/>

                <ProgressBar
                        android:id="@+id/progress_bar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="0"
                        android:visibility="gone"/>

                <TextView
                        android:id="@+id/tv_progress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textSize="12sp"
                        android:visibility="gone"/>
            </LinearLayout>

            <!-- 文件大小行 -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                <TextView
                        android:id="@+id/tv_input_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="输入: 0 MB"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="11sp"/>

                <TextView
                        android:id="@+id/tv_output_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="输出: 0 MB"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="11sp"
                        android:visibility="gone"/>

                <TextView
                        android:id="@+id/tv_size_change"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="↓ 0%"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:visibility="gone"/>

                <TextView
                        android:id="@+id/tv_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="00:00"
                        android:textColor="?android:attr/textColorSecondary"
                        android:textSize="11sp"
                        android:visibility="gone"/>
            </LinearLayout>

            <!-- 输出路径 -->
            <TextView
                    android:id="@+id/tv_output_path"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="点击打开输出文件"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="11sp"
                    android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>
