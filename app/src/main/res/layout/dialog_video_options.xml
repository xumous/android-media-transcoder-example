<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- 输入文件 -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="输入文件"
                android:textSize="14sp"
                android:textStyle="bold"/>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

            <TextView
                    android:id="@+id/tv_input_file"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="middle"
                    android:gravity="center_vertical"
                    android:maxLines="1"
                    android:text="未选择文件"
                    android:textSize="12sp"/>

            <Button
                    android:id="@+id/btn_open_file"
                    style="?attr/materialButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="打开文件"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 视频设置 -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="视频设置"
                android:textSize="14sp"
                android:textStyle="bold"/>

        <!-- 格式 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="另存为:"
                    android:textSize="12sp"/>

            <Spinner
                    android:id="@+id/spinner_format"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
        </LinearLayout>

        <!-- 视频编码器 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="视频编码:"
                    android:textSize="12sp"/>

            <Spinner
                    android:id="@+id/spinner_video_encoder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
        </LinearLayout>

        <!-- 屏幕大小 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="屏幕大小:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_video_size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="原视频尺寸 (如 1920x1080)"
                    android:inputType="text"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 码率 -->
        <LinearLayout
                android:id="@+id/layout_bitrate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="码率:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_video_bitrate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="16000k"
                    android:inputType="text"
                    android:text="16000k"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- CRF -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <CheckBox
                    android:id="@+id/cb_use_crf"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="使用CRF"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_crf_value"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:enabled="false"
                    android:inputType="number"
                    android:text="23"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 每秒帧数 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="每秒帧数:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_frame_rate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="原视频 (1-120)"
                    android:inputType="number"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 宽高比 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="宽高比:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_aspect_ratio"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="自动 (如 16:9)"
                    android:inputType="text"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 二次编码 -->
        <CheckBox
                android:id="@+id/cb_two_pass"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="二次编码"
                android:textSize="12sp"/>

        <!-- 关键帧间隔 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="关键帧间隔:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_keyframe_interval"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="默认"
                    android:inputType="number"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 旋转 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="旋转:"
                    android:textSize="12sp"/>

            <Spinner
                    android:id="@+id/spinner_rotation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
        </LinearLayout>

        <!-- 翻转 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

            <CheckBox
                    android:id="@+id/cb_h_flip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="左右颠倒"
                    android:textSize="12sp"/>

            <CheckBox
                    android:id="@+id/cb_v_flip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="上下颠倒"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 音频设置 -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="音频设置"
                android:textSize="14sp"
                android:textStyle="bold"/>

        <!-- 音频编码器 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="音频编码:"
                    android:textSize="12sp"/>

            <Spinner
                    android:id="@+id/spinner_audio_encoder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
        </LinearLayout>

        <!-- 采样率 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="采样率:"
                    android:textSize="12sp"/>

            <Spinner
                    android:id="@+id/spinner_sample_rate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
        </LinearLayout>

        <!-- 比特率 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="比特率:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_audio_bitrate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:text="320k"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 声道 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="声道:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_channels"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="number"
                    android:text="2"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 音量 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="音量:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_volume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="0-999%"
                    android:inputType="number"
                    android:text="100"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 保留所有流 -->
        <CheckBox
                android:id="@+id/cb_map_all_streams"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:checked="true"
                android:text="保留所有源输入流"
                android:textSize="12sp"/>

        <!-- 输出文件夹 -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="输出文件夹"
                android:textSize="14sp"
                android:textStyle="bold"/>

        <RadioGroup
                android:id="@+id/rg_output_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

            <RadioButton
                    android:id="@+id/rb_source_dir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="输出到源文件目录"
                    android:textSize="12sp"/>

            <RadioButton
                    android:id="@+id/rb_select_dir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择目录"
                    android:textSize="12sp"/>
        </RadioGroup>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

            <TextView
                    android:id="@+id/tv_output_dir"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="middle"
                    android:maxLines="1"
                    android:textSize="12sp"
                    android:visibility="gone"/>

            <Button
                    android:id="@+id/btn_select_output_dir"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:text="选择"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 底部按钮 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

            <Button
                    android:id="@+id/btn_cancel"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="取消"/>

            <Button
                    android:id="@+id/btn_default"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="默认"/>

            <Button
                    android:id="@+id/btn_ok"
                    style="?attr/materialButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="确定"/>

            <Button
                    android:id="@+id/btn_ok_and_start"
                    style="?attr/materialButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1.5"
                    android:text="确定并开始"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
