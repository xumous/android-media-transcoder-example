<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- 输入文件 -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="输入文件"
                android:textSize="14sp"
                android:textStyle="bold"/>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

            <TextView
                    android:id="@+id/tv_input_file"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="middle"
                    android:gravity="center_vertical"
                    android:maxLines="1"
                    android:text="未选择文件"
                    android:textSize="12sp"/>

            <Button
                    android:id="@+id/btn_open_file"
                    style="?attr/materialButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="打开文件"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 音频设置 -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="音频设置"
                android:textSize="14sp"
                android:textStyle="bold"/>

        <!-- 格式 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="格式:"
                    android:textSize="12sp"/>

            <Spinner
                    android:id="@+id/spinner_format"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
        </LinearLayout>

        <!-- 编码器 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="编码器:"
                    android:textSize="12sp"/>

            <Spinner
                    android:id="@+id/spinner_encoder"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
        </LinearLayout>

        <!-- 采样率 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="采样率:"
                    android:textSize="12sp"/>

            <Spinner
                    android:id="@+id/spinner_sample_rate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>
        </LinearLayout>

        <!-- 比特率 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="比特率:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_bitrate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="text"
                    android:text="320k"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 声道 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="声道:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_channels"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="number"
                    android:text="2"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 音量 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="音量:"
                    android:textSize="12sp"/>

            <EditText
                    android:id="@+id/et_volume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="0-999%"
                    android:inputType="number"
                    android:text="100"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 输出文件夹 -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="输出文件夹"
                android:textSize="14sp"
                android:textStyle="bold"/>

        <RadioGroup
                android:id="@+id/rg_output_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

            <RadioButton
                    android:id="@+id/rb_source_dir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="输出到源文件目录"
                    android:textSize="12sp"/>

            <RadioButton
                    android:id="@+id/rb_select_dir"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="选择目录"
                    android:textSize="12sp"/>
        </RadioGroup>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

            <TextView
                    android:id="@+id/tv_output_dir"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="middle"
                    android:maxLines="1"
                    android:textSize="12sp"
                    android:visibility="gone"/>

            <Button
                    android:id="@+id/btn_select_output_dir"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:text="选择"
                    android:textSize="12sp"/>
        </LinearLayout>

        <!-- 底部按钮 -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

            <Button
                    android:id="@+id/btn_cancel"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="取消"/>

            <Button
                    android:id="@+id/btn_default"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="默认"/>

            <Button
                    android:id="@+id/btn_ok"
                    style="?attr/materialButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="确定"/>

            <Button
                    android:id="@+id/btn_ok_and_start"
                    style="?attr/materialButtonStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1.5"
                    android:text="确定并开始"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
